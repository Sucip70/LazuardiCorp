PORT=8080

DATABASE_URL=postgres://postgres:12345678@localhost:5432/postgres?sslmode=disable

JWT_SECRET=change-me-in-production

JWT_EXPIRY_HOURS=72

CORS_ORIGIN=http://localhost:5173



# Asset storage (local for dev, s3 for production)

STORAGE_DRIVER=local

STORAGE_LOCAL_PATH=./storage

STORAGE_PUBLIC_URL=http://localhost:8080/files



# AWS S3 (when STORAGE_DRIVER=s3)

AWS_REGION=us-east-1

AWS_S3_BUCKET=

AWS_ACCESS_KEY_ID=

AWS_SECRET_ACCESS_KEY=

AWS_S3_ENDPOINT=

AWS_S3_PUBLIC_URL=



# Upload validation

ASSET_MAX_SIZE_BYTES=10485760

ASSET_ALLOWED_MIMES=image/jpeg,image/png,image/webp,image/gif,image/svg+xml

# Redis cache (optional — app runs without it)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
CACHE_PREVIEW_TTL=15m
CACHE_COMPONENTS_TTL=24h
CACHE_API_TTL=5m
CACHE_SESSIONS=true

# CDN for static assets (CloudFront / Cloudflare — point at storage origin)
CDN_BASE_URL=
CDN_MAX_AGE=86400

# Deployment (Netlify / Vercel / AWS S3 + CloudFront)
DEPLOY_DEFAULT_PROVIDER=s3
AUTO_DEPLOY_ON_SAVE=false
PREVIEW_PUBLIC_BASE_URL=http://localhost:8080
PREVIEW_TOKEN_TTL=24h
DEPLOY_S3_BUCKET=
DEPLOY_S3_PREFIX=sites/
DEPLOY_S3_CREATE_BUCKET=true
DEPLOY_AWS_REGION=us-east-1
DEPLOY_PUBLIC_BASE_URL=
CLOUDFRONT_DISTRIBUTION_ID=
NETLIFY_TOKEN=
NETLIFY_SITE_ID=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
ACME_EMAIL=
ACME_STAGING=false
ACME_DIRECTORY_URL=

